# ============================================================
# FieldPro SaaS — Environment Variables
# 1. cp .env.example .env
# 2. Fill in every value — nothing ships with placeholders
# 3. Generate SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"
#
# NOTE: Docker Compose env_file parser does NOT strip trailing
# comments — keep comments on their own line, never inline.
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
APP_NAME=FieldPro
APP_VERSION=1.0.0
# ENVIRONMENT: development | staging | production
ENVIRONMENT=development
DEBUG=true
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Public-facing URLs (used in email links, CORS, OAuth callbacks)
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
ALLOWED_HOSTS=localhost,127.0.0.1

# ------------------------------------------------------------
# Database — PostgreSQL
# ------------------------------------------------------------
POSTGRES_USER=fieldpro
POSTGRES_PASSWORD=fieldpro_secret
POSTGRES_DB=fieldpro
POSTGRES_PORT=5432

# Full async URL (used by SQLAlchemy + Alembic). Inside docker compose the
# postgres service is reachable as the "postgres" hostname; on a host pointing
# at the same compose stack via a forwarded port, swap "postgres" → "localhost".
DATABASE_URL=postgresql+asyncpg://fieldpro:fieldpro_secret@postgres:5432/fieldpro

# Sync URL for Alembic migrations (no +asyncpg)
DATABASE_SYNC_URL=postgresql://fieldpro:fieldpro_secret@postgres:5432/fieldpro

# Test database (CI / pytest)
DATABASE_TEST_URL=postgresql+asyncpg://fieldpro:fieldpro_secret@postgres:5432/fieldpro_test

# Connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_PASSWORD=redis_secret
REDIS_PORT=6379
REDIS_URL=redis://:redis_secret@redis:6379/0

# ARQ worker config (DB 1 is the job queue)
ARQ_REDIS_URL=redis://:redis_secret@redis:6379/1
# Concurrent jobs per worker
ARQ_MAX_JOBS=10

# ------------------------------------------------------------
# JWT / Auth
# ------------------------------------------------------------
# Dev defaults below work out-of-the-box. Replace both keys before deploying.
# Generate new keys: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=fieldpro-dev-secret-key-replace-before-deploying-aabbccddeeff00112233445566778899
REFRESH_SECRET_KEY=fieldpro-dev-refresh-key-replace-before-deploying-99887766554433221100ffeeddccbbaa
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# MFA
MFA_ISSUER_NAME=FieldPro

# ------------------------------------------------------------
# CORS
# ------------------------------------------------------------
# JSON array of allowed origins
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ------------------------------------------------------------
# First Platform Super Admin (seeded on first `alembic upgrade head`)
# Change immediately after first login.
# ------------------------------------------------------------
FIRST_SUPERADMIN_EMAIL=admin@fieldpro.dev
FIRST_SUPERADMIN_PASSWORD=ChangeMe123!

# ------------------------------------------------------------
# File Storage — Cloudflare R2 (recommended) or AWS S3
# Cloudflare R2: zero egress fees, S3-compatible API
# ------------------------------------------------------------
# STORAGE_BACKEND: r2 | s3 | local (local = dev only, no credentials needed)
STORAGE_BACKEND=local
UPLOAD_MAX_SIZE_MB=10
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp,application/pdf

# Cloudflare R2
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=fieldpro-uploads
# Custom domain pointing to R2 bucket
R2_PUBLIC_URL=https://uploads.fieldpro.app

# AWS S3 (leave blank if using R2)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1
# AWS_S3_ENDPOINT_URL: leave blank for standard S3
AWS_S3_ENDPOINT_URL=

# ------------------------------------------------------------
# Email — SMTP
# Dev: points to MailHog (override.yml sets SMTP_HOST=mailhog)
# Prod: SendGrid, SES, Resend, Postmark
# ------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_TLS=false
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@fieldpro.app
EMAILS_FROM_NAME=FieldPro

# SendGrid (prod)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_TLS=true
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key

# ------------------------------------------------------------
# SMS — Twilio (Phase 2 — leave blank to disable)
# ------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ------------------------------------------------------------
# Billing — Stripe (Phase 2 — leave blank to disable)
# ------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# From: stripe listen --forward-to localhost:8000/webhooks/stripe
STRIPE_WEBHOOK_SECRET=
# Price ID from Stripe dashboard
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=

# ------------------------------------------------------------
# Integrations (Phase 3 — leave blank to disable)
# ------------------------------------------------------------
# QuickBooks Online
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=http://localhost:8000/api/v1/integrations/quickbooks/callback
# QUICKBOOKS_ENVIRONMENT: sandbox | production
QUICKBOOKS_ENVIRONMENT=sandbox

# Google Maps (route optimization, geocoding)
GOOGLE_MAPS_API_KEY=

# ------------------------------------------------------------
# Monitoring & Observability
# ------------------------------------------------------------
# SENTRY_DSN: leave blank to disable (dev)
SENTRY_DSN=
# SENTRY_DSN=https://your-key@o0.ingest.sentry.io/your-project-id
# SENTRY_TRACES_SAMPLE_RATE: 10% of transactions
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=development

# ------------------------------------------------------------
# Frontend — Next.js (NEXT_PUBLIC_* are exposed to the browser)
# ------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=FieldPro
NEXT_PUBLIC_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
# NEXT_PUBLIC_MAPBOX_TOKEN: alternative to Google Maps
NEXT_PUBLIC_MAPBOX_TOKEN=

# ------------------------------------------------------------
# Dev Tools (local only)
# ------------------------------------------------------------
PGADMIN_EMAIL=admin@fieldpro.dev
PGADMIN_PASSWORD=pgadmin_secret
PGADMIN_PORT=5050

# Web Concurrency (prod only — gunicorn workers)
WEB_CONCURRENCY=4
